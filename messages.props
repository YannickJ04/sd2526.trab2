MESSAGES_REST_SERVER_MAINCLASS=messages REST server class (e.g. sd2526.trab.srv.rest.RestMessagesImpl)
MESSAGES_REST_PORT=messages REST server port (e.g. 8080)
MESSAGES_REST_EXTRA_ARGS=extra arguments for messages REST server (optional)
USERS_REST_SERVER_MAINCLASS=users REST server class (e.g. sd2526.trab.srv.rest.RestUsersImpl)
USERS_REST_PORT=users REST server port (e.g. 8081)
USERS_REST_EXTRA_ARGS=extra arguments for users REST server (optional)
GATEWAY_REST_SERVER_MAINCLASS=gateway REST server class (e.g. sd2526.trab.srv.rest.RestGatewayImpl)
GATEWAY_REST_PORT=gateway REST server port (e.g. 8082)
GATEWAY_REST_EXTRA_ARGS=extra arguments for gateway REST server (optional)
USERS_GRPC_SERVER_MAINCLASS=users GRPC server class (e.g. sd2526.trab.srv.grpc.GRPCUsersImpl)
USERS_GRPC_PORT=users GRPC server port (e.g. 8083)
USERS_GRPC_EXTRA_ARGS=extra arguments for users GRPC server (optional)
DISCOVERY_MULTICAST_IP=multicast address for discovery (e.g. 226.226.226.226)
DISCOVERY_MULTICAST_PORT=port for discovery (e.g. 2266)
MESSAGES_REST_PROXY_SERVER_MAINCLASS=messages REST proxy server class (external service)
MESSAGES_REST_PROXY_PORT=messages REST proxy server port
MESSAGES_REST_PROXY_EXTRA_ARGS=extra arguments for messages REST proxy server (optional)
MESSAGES_REP_SERVER_MAINCLASS=replicated messages REST server class
MESSAGES_REP_PORT=replicated messages REST server port
MESSAGES_REP_EXTRA_ARGS_FIRST=extra arguments for the first replicated messages REST server (optional)
MESSAGES_REP_EXTRA_ARGS_OTHER=extra arguments for the other replicated messages REST servers (optional)
USERS_KEYSTORES=keystores for the users server (e.g. users.ourorg0,users.jks,users0pwd)
SERVERS_KEYSTORES=keystores for the messages servers - 1 per server in two replicated domains and one non-replicated domain (e.g. messages0.ourorg0,messages0-0.jks,messages0-0pwd messages1.ourorg0,messages1-0.jks,messages1-0pwd messages2.ourorg0,messages2-0.jks,messages2-0pwd messages0.ourorg1,messages0-1.jks,messages0-1pwd messages1.ourorg1,messages1-1.jks,messages1-1pwd  messages2.ourorg1,messages2-1.jks,messages2-1pwd messages0.ourorg2,messages0-2.jks,messages0-2pwd)
CLIENT_TRUSTSTORE=name of the file with the truststore for the clients (e.g. client-truststore.jks)
CLIENT_TRUSTSTORE_PWD=truststore password